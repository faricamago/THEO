{
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "npm install --workspaces=false && cd frontend && npm install && cd ../api && npm install",
  "outputDirectory": "frontend/dist",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/src/index.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/src/index.ts"
    }
  ]
}
